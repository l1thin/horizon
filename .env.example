# Horizon .env template

# LLM Provider Configuration
LLM_PROVIDER=claude # Options: claude, openai, gemini

# API Keys
CLAUDE_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_google_key_here

# Database Configurations
SUPABASE_URL=postgresql://horizon:horizon@db:5432/horizon
DATABASE_URL=postgresql://horizon:horizon@db:5432/horizon

# Model Overrides
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-audio-preview
GEMINI_MODEL=gemini-1.5-pro
